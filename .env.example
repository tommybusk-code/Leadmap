# Copy to .env for local development (do not commit .env).

# Google OAuth — Web application client (see DEPLOY_RENDER.md)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Session signing (use a long random string in production)
FLASK_SECRET_KEY=change-me

# Public base URL for OAuth redirect and invite links (no trailing slash).
# Local:
LEADMAP_PUBLIC_URL=http://127.0.0.1:5050
# On Render you can omit this — the app falls back to RENDER_EXTERNAL_URL.

# First Google login with this email becomes tenant owner (only when user DB is empty)
LEADMAP_BOOTSTRAP_OWNER_EMAIL=

# Set to 1 to disable login enforcement (not for production)
# LEADMAP_AUTH_DISABLED=1
